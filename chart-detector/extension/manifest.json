{
  "manifest_version": 3,
  "name": "News Chart Detector",
  "version": "1.0",
  "description": "Automatically saves chart like images while browsing from kbs/sbs/mbc",
  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
  "<all_urls>"
],
  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "whitelist.js",
        "utils.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icons/icon128.png"
  }
}